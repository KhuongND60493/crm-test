## 3. DB Error Handling (MySQL / PostgreSQL)

> **Đọc `docs/project_overview.md`** để biết project dùng DB gì trước khi implement.

```csharp
// ── MySQL (Pomelo) ─────────────────────────────────────────
// Package: Pomelo.EntityFrameworkCore.MySql
// MySqlException.Number codes:
//   1062 = Duplicate entry (unique violation)
//   1451 = FK constraint (cannot delete parent)
//   1452 = FK constraint (no parent row)
//   1213 = Deadlock found
//   1205 = Lock wait timeout

catch (OperationCanceledException) { throw; }
catch (DbUpdateException ex) when (
    ex.InnerException is MySqlException my && my.Number == 1062)
    => Result.Failure(DbErrors.DuplicateKey);
catch (DbUpdateException ex) when (
    ex.InnerException is MySqlException my && my.Number == 1213)
    => Result.Failure(DbErrors.Deadlock);

// ── PostgreSQL (Npgsql) ────────────────────────────────────
// catch (DbUpdateException ex) when (
//     ex.InnerException is PostgresException pg
//     && pg.SqlState == "23505")  // UniqueViolation
//     => Result.Failure(DbErrors.DuplicateKey);

// ── Common (cả hai) ────────────────────────────────────────
catch (DbUpdateConcurrencyException)
    => Result.Failure(DbErrors.ConcurrencyConflict);
// KHÔNG: catch (Exception) { return null; } — silent failure
// KHÔNG: throw ex; → dùng throw; giữ stack trace
```

