## 5. Resource Management & DI

```csharp
// DI Lifetimes:
// Singleton  → IMemoryCache, HttpClientFactory, ActivitySource, Meter, IOptions<T>
// Scoped     → DbContext, IUnitOfWork, ICurrentUser, IOptionsSnapshot<T>
// Transient  → Validators, mappers, calculators
// ⚠️ Không inject Scoped vào Singleton → captive dependency

// ✅ BackgroundService — dùng IServiceScopeFactory
public sealed class MetricsWorker : BackgroundService
{
    private readonly IServiceScopeFactory _scopeFactory;
    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        while (!stoppingToken.IsCancellationRequested)
        {
            try {
                await using var scope = _scopeFactory.CreateAsyncScope();
                await scope.ServiceProvider
                    .GetRequiredService<IMetricsPusher>()
                    .PushBatchAsync(stoppingToken);
            }
            catch (OperationCanceledException) { break; }
            catch (Exception ex) {
                _logger.LogError(ex, "Batch failed");
                await Task.Delay(30_000, stoppingToken); continue;
            }
            await Task.Delay(_opts.CurrentValue.IntervalMs, stoppingToken);
        }
    }
}

// ✅ Transaction — ngắn nhất có thể
await using var tx = await _db.Database
    .BeginTransactionAsync(IsolationLevel.ReadCommitted, ct);
try   { _db.Orders.Add(order); await _db.SaveChangesAsync(ct); await tx.CommitAsync(ct); }
catch { await tx.RollbackAsync(ct); throw; }
// Side effects (publish event) SAU commit
```

